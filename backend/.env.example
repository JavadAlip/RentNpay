PORT=5000

# Primary connection (Atlas SRV or local):
MONGODB_URI=mongodb://127.0.0.1:27017/rentpay

# Optional: when MONGODB_URI is Atlas SRV and DNS fails, server tries this next:
# MONGODB_URI_FALLBACK=mongodb://127.0.0.1:27017/rentpay

# Atlas example (SRV — needs working DNS):
# MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/rentpay?retryWrites=true&w=majority

JWT_SECRET=your_super_secret_jwt_key_change_in_production
